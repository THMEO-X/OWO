module.exports = async (client, message, state) => {
  if (message.author.id !== client.user.id) return;
  if (message.content !== "pause") return;

  if (state.paused) {
    console.log("⏸️ Bot đang pause rồi");
  } else {
    state.paused = true;
    await message.edit("stops");
    console.log("⏸️ Pause thủ công");
  }
};